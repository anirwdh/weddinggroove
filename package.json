{
  "name": "wedding-groove",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "optimize": "npm run build && npm run optimize:images && npm run optimize:videos",
    "optimize:images": "find public/assets/images -name '*.jpg' -o -name '*.png' -exec cwebp -q 80 {} -o {}.webp \\;",
    "optimize:videos": "find public/assets/videos -name '*.mp4' -exec ffmpeg -i {} -c:v libx264 -crf 28 -preset medium -c:a aac -b:a 128k -movflags +faststart {}.optimized.mp4 \\;"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "framer-motion": "^11.0.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.576.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-intersection-observer": "^9.8.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
